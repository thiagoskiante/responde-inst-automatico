# Claude API (obtenha em console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# Meta / Instagram (obtenha em developers.facebook.com → Graph API Explorer)
# IMPORTANTE: Use o token da PÁGINA, não o token de usuário!
META_PAGE_ACCESS_TOKEN=SEU_TOKEN_DA_PAGINA_AQUI

# ID da Página do Facebook (GET me?fields=id com a Página selecionada no Graph API Explorer)
META_PAGE_ID=SEU_PAGE_ID_AQUI

# Token de verificação do Webhook (escolha qualquer palavra secreta)
META_VERIFY_TOKEN=minha-senha-secreta
